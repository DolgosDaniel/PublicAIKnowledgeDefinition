{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paik.dev/schema/api-spec.schema.json",
  "title": "PAIK API Spec",
  "description": "The contract a service exposes. See SPEC.md section 5.",
  "allOf": [{ "$ref": "./common.schema.json" }],
  "type": "object",
  "properties": {
    "doc_type": { "const": "api-spec" },
    "type": {
      "type": "string",
      "enum": [
        "swaggerhub",
        "stoplight",
        "redocly",
        "openapi-file",
        "grpc",
        "graphql",
        "asyncapi",
        "soap-wsdl",
        "other"
      ]
    },
    "base_url": { "type": "string", "format": "uri" },
    "api_id": { "type": "string" },
    "version": { "type": "string" },
    "spec_url": {
      "type": "string",
      "format": "uri",
      "description": "Direct link to the raw OpenAPI/AsyncAPI document"
    },
    "served_by_env": {
      "type": "object",
      "description": "Map of environment id -> spec version actually deployed there",
      "additionalProperties": { "type": "string" }
    },
    "custom_fields": {
      "type": "object",
      "description": "Only used when type is \"other\""
    }
  },
  "if": {
    "properties": { "type": { "const": "other" } },
    "required": ["type"]
  },
  "then": {
    "required": ["custom_fields"]
  },
  "required": ["type", "base_url", "api_id", "version", "spec_url"],
  "unevaluatedProperties": false
}
